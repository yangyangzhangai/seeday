{
  "name": "youware-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite",
    "build": "vite build",
    "build:ios": "cross-env VITE_PAYMENT_MODE=iap VITE_API_BASE=https://tshine2-13-new.vercel.app vite build",
    "build:web": "cross-env VITE_PAYMENT_MODE=stripe vite build",
    "preview": "vite preview",
    "lint:max-lines": "node ./scripts/check-max-lines.mjs",
    "lint:docs-sync": "node ./scripts/check-doc-sync.mjs",
    "lint:state-consistency": "node ./scripts/check-state-consistency.mjs",
    "lint:secrets": "node ./scripts/check-secrets.mjs",
    "lint:all": "npm run lint:secrets && npm run lint:max-lines && npm run lint:docs-sync && npx tsc --noEmit",
    "eval:live-input:gold": "python ./scripts/evaluate_live_input_gold.py --lang zh",
    "eval:classification:pr0": "npx vite-node scripts/multilingual_classification_benchmark.ts",
    "eval:classification:pr0:artifact": "npx vite-node scripts/multilingual_classification_benchmark.ts --artifact-out docs/benchmarks/pr0-baseline.latest.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "sync:plants": "node scripts/sync-plant-registry.js",
    "prepare": "node ./scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@chinese-fonts/lxgwwenkai": "^3.0.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/material-symbols-outlined": "^5.2.39",
    "@headlessui/react": "^1.7.18",
    "@supabase/supabase-js": "^2.94.1",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.26.12",
    "framer-motion": "^11.0.8",
    "gsap": "^3.13.0",
    "html2canvas": "^1.4.1",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.533.0",
    "openai": "^5.7.0",
    "react": "^18.3.1",
    "react-calendar": "^6.0.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.30.1",
    "react-use": "^17.6.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.67",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@youware/vite-plugin-react": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vercel": "^37.0.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.9"
  }
}
