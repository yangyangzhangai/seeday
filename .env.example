# =========================================
# Server-only API Keys (不要暴露到前端)
# =========================================

# Chutes API Key
# 用于: /api/chat /api/report /api/diary /api/annotation /api/stardust
# 获取地址: https://chutes.ai/
CHUTES_API_KEY=your_chutes_api_key_here

# Zhipu API Key
# 用于: /api/classify (model: glm-4.7-flash)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# =========================================
# Supabase (前端公开配置)
# =========================================

# Supabase 项目 URL
VITE_SUPABASE_URL=your_supabase_url_here

# Supabase Anon Key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =========================================
# Local dev (optional)
# =========================================

VITE_PORT=3000
VITE_API_PROXY=
