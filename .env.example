# =========================================
# Server-only API Keys (不要暴露到前端)
# =========================================

# Chutes API Key
# 用于: /api/report /api/diary /api/plant-diary
# 获取地址: https://chutes.ai/
CHUTES_API_KEY=your_chutes_api_key_here

# OpenAI API Key
# 用于: /api/diary /api/extract-profile
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Qwen API Key
# 用于: /api/classify（默认模型 qwen-plus）/api/magic-pen-parse fallback provider /api/todo-decompose(zh: qwen-plus)
# 获取地址: https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini API Key
# 用于: /api/annotation(en/it: gemini2.0-flash) /api/todo-decompose(en/it)
# 获取地址: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# DeepSeek API Key
# 用于: /api/annotation(zh: deepseek-chat)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 可选：annotation provider 兼容端点
ANNOTATION_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANNOTATION_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
ANNOTATION_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 可选：分类器模型（默认 qwen-plus）
CLASSIFY_MODEL=qwen-plus

# 可选：待办拆解模型（默认 gemini-2.5-flash）
TODO_DECOMPOSE_MODEL=gemini-2.5-flash

# 可选：待办拆解 Gemini 自动降级模型（默认 gemini-2.5-flash）
TODO_DECOMPOSE_GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# 可选：中文待办拆解模型（默认 qwen-plus）
TODO_DECOMPOSE_MODEL_ZH=qwen-plus

# 可选：待办拆解 Gemini 原生接口地址
TODO_DECOMPOSE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 可选：待办拆解详细日志开关（true 时输出 provider/model/原始响应预览）
TODO_DECOMPOSE_VERBOSE_LOGS=false

# Zhipu API Key
# 用于: /api/magic-pen-parse primary provider (model: glm-4.7-flash)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Qwen 兼容端点（国际）
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# 可选：魔法笔兜底模型（默认 qwen-flash）
MAGIC_PEN_FALLBACK_MODEL=qwen-flash

# =========================================
# iOS (Capacitor) API Base
# =========================================

# iOS 打包后不会自带 Vercel Serverless Functions。
# 若要让原生 App 调用线上后端，请把 API 基地址指向你的 Vercel 生产域名。
# Web 场景可留空，默认走相对路径 /api。
VITE_API_BASE=https://your-vercel-project.vercel.app

# =========================================
# Supabase (前端公开配置)
# =========================================

# Supabase 项目 URL
VITE_SUPABASE_URL=https://oxsbukofipeoikirkyyy.supabase.co

# Supabase Anon Key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: OAuth redirect URL for Capacitor native app
# Default: com.seeday.app://auth/callback
VITE_IOS_OAUTH_REDIRECT_URL=com.seeday.app://auth/callback

# Supabase Service Role Key (server only; used by admin telemetry dashboard APIs)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional allowlist for live input telemetry dashboard access
LIVE_INPUT_ADMIN_EMAILS=your_admin_email@example.com
LIVE_INPUT_ADMIN_USER_IDS=

# Optional: whether to persist raw user input text in telemetry rows
LIVE_INPUT_TELEMETRY_STORE_RAW_TEXT=false

# =========================================
# Local dev / QA switches (build-time)
# =========================================

# Force allow previewing the onboarding flow even for "old accounts":
# - Visit: /onboarding?forceOnboarding=1
# - Or set: VITE_FORCE_ONBOARDING=1
VITE_FORCE_ONBOARDING=false

# =========================================
# Membership / iOS IAP (server + ios build)
# =========================================

# iOS 构建时 API 绝对路径（Capacitor 原生 app 中相对路径无法指向 Vercel，必须设置）
# 填写你的 Vercel 生产 URL，例如：https://your-app.vercel.app
# Web build 不需要设置（留空使用相对路径 /api）
VITE_API_BASE=https://seeday.vercel.app

# Build-time payment mode
VITE_PAYMENT_MODE=iap

# iOS product IDs used by @payment iap adapter
VITE_IAP_PRODUCT_MONTHLY=seeday.pro.monthly
VITE_IAP_PRODUCT_ANNUAL=seeday.pro.annual

# Apple App Store Server API credentials for /api/subscription
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_BUNDLE_ID=com.seeday.app
APPLE_IAP_PRODUCT_MONTHLY=seeday.pro.monthly
APPLE_IAP_PRODUCT_ANNUAL=seeday.pro.annual

# Local debug only: bypass Apple verification and trust transaction payload
APPLE_IAP_VERIFY_BYPASS=false

# =========================================
# Membership / Web Stripe (server + web build)
# =========================================

# Stripe secret key used by /api/subscription stripe_checkout/stripe_finalize
STRIPE_SECRET_KEY=

# Stripe recurring price IDs (Dashboard -> Product -> Price ID)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
