{
  "functions": {
    "api/magic-pen-parse.ts": {
      "maxDuration": 20
    }
  },
  "rewrites": [
    { "source": "/api/todo-decompose", "destination": "/api/classify" },
    { "source": "/api/plant-asset-telemetry", "destination": "/api/live-input-telemetry" },
    {
      "source": "/supabase-proxy/(.*)",
      "destination": "https://oxsbukofipeoikirkyyy.supabase.co/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
